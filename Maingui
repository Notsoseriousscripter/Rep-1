-- STORE ORIGINAL SIZES & POSITIONS
local originalSizes = {}
local originalPositions = {}
local function storeOriginals(obj)
    originalSizes[obj] = {XScale=obj.Size.X.Scale, XOffset=obj.Size.X.Offset,
                          YScale=obj.Size.Y.Scale, YOffset=obj.Size.Y.Offset}
    originalPositions[obj] = {XScale=obj.Position.X.Scale, XOffset=obj.Position.X.Offset,
                              YScale=obj.Position.Y.Scale, YOffset=obj.Position.Y.Offset}
end

-- RESCALE FUNCTION
local function rescaleMenu(scale)
    Menu.Size = UDim2.new(0,320*scale,0,480*scale)
    for obj, s in pairs(originalSizes) do
        local p = originalPositions[obj]
        obj.Size = UDim2.new(s.XScale,s.XOffset*scale,s.YScale,s.YOffset*scale)
        obj.Position = UDim2.new(p.XScale,p.XOffset*scale,p.YScale,p.YOffset*scale)
    end
end

