Players.PlayerAdded:Connect(function(plr)
    if plr ~= LocalPlayer then
        SelectedPlayers[plr] = true
        allSelected = true
        SelectAll.Text = "Deselect All"
        if Menu.Visible then task.wait(0.2); refreshPlayerList() end
    end
end)
Players.PlayerRemoving:Connect(function(plr)
    SelectedPlayers[plr] = nil
    if Menu.Visible then refreshPlayerList() end
end)

-- MAIN LOOP
spawn(function()
    while true do
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            if FireEnabled then
                for plr, sel in pairs(SelectedPlayers) do
                    if sel and plr.Character then
                        Remote:FireServer("Viltrumite","M1",plr.Character,"BoostCombatEnd",1,103074409872436.2)
                    end
                end
            end
            if KillAuraEnabled then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer and plr.Character then
                        local h = plr.Character:FindFirstChild("HumanoidRootPart")
                        if h and (h.Position - hrp.Position).Magnitude <= AuraRadius then
                            Remote:FireServer("Viltrumite","M1",plr.Character,"BoostCombatEnd",1,103074409872436.2)
                        end
                    end
                end
            end
            if HailMaryEnabled then
                local target = Workspace.Characters:FindFirstChild("HailMaryOfficial")
                local hit = target and target:FindFirstChild("Hitboxes") and target.Hitboxes:FindFirstChild("LeftLegSpot")
                if target and hit then
                    local args = {[1]="Viltrumite",[2]="CustomRigHit",[3]=target,[4]=hit,[5]="BoostHit"}
                    Remote:FireServer(unpack(args))
                end
            end
            if CounterEnabled then
                local args = {[1]="Viltrumite",[2]="Counter",[4]="CounterAdd",[6]=103074409885808.81}
                Remote:FireServer(unpack(args))
            end
        end
        task.wait(0.05)
    end
end)

