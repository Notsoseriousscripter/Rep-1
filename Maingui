                btn.TextColor3 = Color3.new(1,1,1)
                btn.Parent = ScreenGui
                Instance.new("UICorner", btn)
                btn.Draggable = true
                btn.Active = true
                btn.MouseButton1Click:Connect(function()
                    CharacterInput.Text = name
                    pcall(function() LocalPlayer.Settings.moveset.Value = name end)
                end)
                DraggableCharacterButtons[name] = btn
            end
        end
