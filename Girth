local ClickSoundId = nil
pcall(function()
    local getasset = getsynasset or getcustomasset
    if getasset and writefile then
        local url = "https://raw.githubusercontent.com/Notsoseriousscripter/Decodeinasma/main/ezgif-1065ef8f7c627c89.mp3"
        if not isfile("click.mp3") then
            writefile("click.mp3", game:HttpGet(url))
        end
        ClickSoundId = getasset("click.mp3")
    end
end)

local function PlayClick()
    if not ClickSoundId then return end
    local s = Instance.new("Sound")
    s.SoundId = ClickSoundId
    s.Volume = 2
    s.Parent = SoundService
    s:Play()
    s.Ended:Connect(function() s:Destroy() end)
end

local function loadImage(name, url)
    local asset = "rbxthumb://type=Asset&id=0&w=420&h=420"
    pcall(function()
        local getasset = getsynasset or getcustomasset
        if getasset and writefile then
            if not isfile(name) then
                writefile(name, game:HttpGet(url))
            end
            asset = getasset(name)
        end
    end)
    return asset
end

