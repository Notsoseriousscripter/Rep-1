local function GetNape(plr)
    local obj=workspace:FindFirstChild("Objects")
    local chars=obj and obj:FindFirstChild("Characters")
    local char=chars and chars:FindFirstChild(plr.Name)
    if not char then return end
    for _,v in pairs(char:GetChildren()) do
        if v.Name ~= "Armored" and v:FindFirstChild("Nape") then
            return v.Nape
        end
    end
end

local function HasTool(plr)
    local char = plr.Character
    if not char then return false end
    for _,v in pairs(char:GetChildren()) do
        if v:IsA("Tool") then
            return true
        end
    end
    return false
end

local LastThrow=0

RunService.RenderStepped:Connect(function()
    local myChar=LocalPlayer.Character
    local myRoot=myChar and myChar:FindFirstChild("HumanoidRootPart")

    for _,plr in ipairs(Players:GetPlayers()) do
        if plr==LocalPlayer then continue end
        if Settings.TeamCheck and plr.Team==LocalPlayer.Team then continue end

        local nape=GetNape(plr)
        local char=plr.Character
        local hitbox=char and char:FindFirstChild("PlayerHitbox")

        --------------------------------------------------
        -- 🔥 SHIFTER LOGIC (ELDIAN LOCK)
        --------------------------------------------------
        if nape then
            local pos,vis=Camera:WorldToViewportPoint(nape.Position)

            -- ✅ Kill Aura ONLY if Eldian
            if KillAura and IsEldian() and myRoot and (nape.Position-myRoot.Position).Magnitude<=200 then
                ReplicatedStorage.Remotes.Blades.Hit:FireServer(nape,DamageBoost and 999 or 686)
            end

            -- ✅ ThunderFarm ONLY if Eldian
            if ThunderFarm and IsEldian() and myRoot then
                local targetPos = nape.Position - (nape.CFrame.LookVector * 80)

                TweenService:Create(
                    myRoot,
                    TweenInfo.new(TweenSpeed),
                    {CFrame=CFrame.new(targetPos)}
                ):Play()

                if tick() - LastThrow >= 0.25 then
                    LastThrow = tick()

                    ReplicatedStorage.Remotes.Thunderspear.Refill:FireServer()

                    local cf = CFrame.new(nape.Position)
                    ReplicatedStorage.Remotes.Thunderspear.Throw:FireServer("Left",cf)
                end
            end

            --------------------------------------------------
            -- ESP
            --------------------------------------------------
            if ShifterESP and vis and char and char.Parent and nape.Parent then
                if not Boxes then Boxes={} end
                if not Boxes[plr] then
                    local b=Drawing.new("Square")
                    b.Color=Color3.fromRGB(170,0,255)
                    b.Thickness=2
                    b.Filled=false
                    Boxes[plr]=b
                end

                local size=3000/pos.Z
                local b=Boxes[plr]
                b.Size=Vector2.new(size,size*1.5)
                b.Position=Vector2.new(pos.X-size/2,pos.Y-size/1.5)
                b.Visible=true
            else
                if Boxes and Boxes[plr] then
                    Boxes[plr].Visible=false
                end
            end

            --------------------------------------------------
            -- TRACERS
            --------------------------------------------------
            if Tracers and vis and char and char.Parent then
                if not Lines then Lines={} end
                if not Lines[plr] then
                    local l=Drawing.new("Line")
                    l.Color=Color3.fromRGB(170,0,255)
                    l.Thickness=1
                    Lines[plr]=l
                end

                local l=Lines[plr]
                l.From=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)
                l.To=Vector2.new(pos.X,pos.Y)
                l.Visible=true
            else
                if Lines and Lines[plr] then
                    Lines[plr].Visible=false
                end
            end
        else
            if Boxes and Boxes[plr] then Boxes[plr].Visible=false end
            if Lines and Lines[plr] then Lines[plr].Visible=false end
        end

        --------------------------------------------------
        -- 🔥 PLAYER KILL AURA (ELDIAN LOCK)
        --------------------------------------------------
        if PlayerKillAura and IsEldian() and myRoot and char and hitbox then
            if (hitbox.Position - myRoot.Position).Magnitude <= 150 then
                ReplicatedStorage.Remotes.Blades.Hit:FireServer(hitbox,999)
            end
        end

        --------------------------------------------------
        -- PLAYER AUTOFARM (ELDIAN LOCK)
        --------------------------------------------------
        if AutoFarmPlayers and IsEldian() and myRoot and char and hitbox and HasTool(plr) then
            if FarmMode=="Players" or FarmMode=="Both" then
                TweenService:Create(
                    myRoot,
                    TweenInfo.new(TweenSpeed),
                    {CFrame=hitbox.CFrame}
                ):Play()

                ReplicatedStorage.Remotes.Blades.Hit:FireServer(hitbox,999)
            end
        end

        --------------------------------------------------
        -- TITAN AUTOFARM (ELDIAN LOCK)
        --------------------------------------------------
        if AutoFarmPlayers and IsEldian() and nape then
            if FarmMode=="Titans" or FarmMode=="Both" then
                TweenService:Create(
                    myRoot,
                    TweenInfo.new(TweenSpeed),
                    {CFrame=nape.CFrame}
                ):Play()

                ReplicatedStorage.Remotes.Blades.Hit:FireServer(nape,999)
            end
        end
    end
end)

