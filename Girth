local function GetCursor()        
    return UserInputService.TouchEnabled and (Camera.ViewportSize/2) or UserInputService:GetMouseLocation()        
end        
        
local function IsEnemy(plr)        
    if plr==LocalPlayer then return false end        
    if Settings.TeamCheck and plr.Team==LocalPlayer.Team then return false end        
    return true        
end        
        
local function GetNearest()        
    local closest,distMin=nil,math.huge        
    local myRoot=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")        
    if not myRoot then return nil end        
        
    for _,plr in ipairs(Players:GetPlayers()) do        
        if not IsEnemy(plr) then continue end        
        local char=plr.Character        
        if not char then continue end        
        
        local part=char:FindFirstChild(Settings.HitPart)        
        local hum=char:FindFirstChildOfClass("Humanoid")        
        local root=char:FindFirstChild("HumanoidRootPart")        
        
        if not part or not hum or hum.Health<=0 or not root then continue end        
        
        local dist=(root.Position-myRoot.Position).Magnitude        
        if dist<distMin then        
            distMin=dist        
            closest=part        
        end        
    end        
        
    return closest        
end        
        
local LockedTarget=nil        
        
local circle=Drawing.new("Circle")        
circle.Thickness=1        
circle.Filled=false        
        
local ESP={}        
        
local function CreateESP(plr)        
    local box=Drawing.new("Square")        
    box.Color=Color3.fromRGB(255,0,0)        
    box.Thickness=2        
    box.Filled=false        
    box.Visible=false        
    ESP[plr]=box        
end        
        
for _,plr in ipairs(Players:GetPlayers()) do        
    if plr~=LocalPlayer then CreateESP(plr) end        
end        
        
Players.PlayerAdded:Connect(function(plr)        
    if plr~=LocalPlayer then CreateESP(plr) end        
end)        
        
Players.PlayerRemoving:Connect(function(plr)        
    if ESP[plr] then ESP[plr]:Remove() ESP[plr]=nil end        
end)        
        
task.defer(function()        
    Settings.Enabled=false        
    Settings.ESPEnabled=false        
    Settings.ShowFOV=false        
end)        
        
RunService.RenderStepped:Connect(function()        
    if Settings.ShowFOV then        
        circle.Visible=true        
        circle.Position=GetCursor()        
        circle.Radius=Settings.FOV        
    else        
        circle.Visible=false        
    end        
        
    if Settings.Enabled then        
        local target=GetNearest()        
        LockedTarget=target        
        if target then        
            Camera.CFrame=CFrame.new(Camera.CFrame.Position,target.Position)        
        end        
    else        
        LockedTarget=nil        
    end        
        
    for plr,box in pairs(ESP) do        
        if not Settings.ESPEnabled or not IsEnemy(plr) then        
            box.Visible=false        
            continue        
        end        
        
        local char=plr.Character        
        local hrp=char and char:FindFirstChild("HumanoidRootPart")        
        local hum=char and char:FindFirstChildOfClass("Humanoid")        
        
        if not hrp or not hum or hum.Health<=0 then        
            box.Visible=false        
            continue        
        end        
        
        local pos,visible=Camera:WorldToViewportPoint(hrp.Position)        
        if visible then        
            local size=3000/pos.Z        
            box.Size=Vector2.new(size,size*1.5)        
            box.Position=Vector2.new(pos.X-size/2,pos.Y-size/1.5)        
            box.Visible=true        
        else        
            box.Visible=false        
        end        
    end        
end)        
        
local oldIndex        
oldIndex=hookmetamethod(game,"__index",newcclosure(function(self,key)        
    if not checkcaller() and Settings.Enabled and self==Mouse then        
        local target=LockedTarget or GetNearest()        
        if target then        
            if key=="Target" then return target        
            elseif key=="Hit" then return target.CFrame        
            elseif key=="UnitRay" then        
                return Ray.new(Camera.CFrame.Position,(target.Position-Camera.CFrame.Position).Unit)        
            end        
        end        
    end        
    return oldIndex(self,key)        
end))
