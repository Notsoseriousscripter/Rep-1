                    Lines[plr].Visible=false
                end
            end
        else
            if Boxes[plr] then Boxes[plr].Visible=false end
            if Lines[plr] then Lines[plr].Visible=false end
        end

        if PlayerKillAura and myRoot and char and hitbox then
            if (hitbox.Position - myRoot.Position).Magnitude <= 150 then
                ReplicatedStorage.Remotes.Blades.Hit:FireServer(hitbox,999)
            end
