local function IsEldian()
    return LocalPlayer.Team and LocalPlayer.Team.Name == "Eldian"
end

local function GetNape(plr)
    local obj=workspace:FindFirstChild("Objects")
    local chars=obj and obj:FindFirstChild("Characters")
    local char=chars and chars:FindFirstChild(plr.Name)
    if not char then return end
    for _,v in pairs(char:GetChildren()) do
        if v.Name ~= "Armored" and v:FindFirstChild("Nape") then
            return v.Nape
        end
    end
end

local function HasTool(plr)
    local char = plr.Character
    if not char then return false end
    for _,v in pairs(char:GetChildren()) do
        if v:IsA("Tool") then
            return true
        end
    end
    return false
end

local function UseMedkit()
    local char = LocalPlayer.Character
    if not char then return end

    local hasMedkit = char:FindFirstChild("Medkit") or LocalPlayer.Backpack:FindFirstChild("Medkit")

    if not hasMedkit then
        pcall(function()
            ReplicatedStorage.Remotes.General.BuySupply:InvokeServer("Medkit")
        end)
    end

    local tool = char:FindFirstChild("Medkit") or LocalPlayer.Backpack:FindFirstChild("Medkit")
    if tool then
        tool.Parent = char
        pcall(function()
            tool:Activate()
        end)
    end
end

local LastThrow = 0
local LastHeal = 0
local Tweening = false

RunService.RenderStepped:Connect(function()
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")

    if SemiGod and myHum and myHum.Health > 0 then
        if myHum.Health <= (myHum.MaxHealth * 0.7) then
            if tick() - LastHeal > 2 then
                LastHeal = tick()
                UseMedkit()
            end
        end
    end

    if not IsEldian() then return end
    if not myRoot then return end

    for _,plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if Settings.TeamCheck and plr.Team == LocalPlayer.Team then continue end

        local nape = GetNape(plr)
        local char = plr.Character
        local hitbox = char and char:FindFirstChild("PlayerHitbox")

        if nape then
            local pos, vis = Camera:WorldToViewportPoint(nape.Position)

            if KillAura and (nape.Position - myRoot.Position).Magnitude <= 180 then
                ReplicatedStorage.Remotes.Blades.Hit:FireServer(nape, DamageBoost and 999 or 686)
            end

            if ThunderFarm then
                local targetPos = nape.Position - (nape.CFrame.LookVector * 60)

                if not Tweening then
                    Tweening = true
                    local tween = TweenService:Create(
                        myRoot,
                        TweenInfo.new(TweenSpeed, Enum.EasingStyle.Linear),
                        {CFrame = CFrame.new(targetPos)}
                    )
                    tween:Play()
                    tween.Completed:Wait()
                    Tweening = false
                end

                if tick() - LastThrow >= 0.35 then
                    LastThrow = tick()
                    ReplicatedStorage.Remotes.Thunderspear.Refill:FireServer()
                    ReplicatedStorage.Remotes.Thunderspear.Throw:FireServer("Left", CFrame.new(nape.Position))
                end
            end

            if ShifterESP and vis then
                if not Boxes[plr] then
                    local b = Drawing.new("Square")
                    b.Color = Color3.fromRGB(170,0,255)
                    b.Thickness = 2
                    b.Filled = false
                    Boxes[plr] = b
                end

                local size = 2500 / pos.Z
                local b = Boxes[plr]
                b.Size = Vector2.new(size, size * 1.4)
                b.Position = Vector2.new(pos.X - size/2, pos.Y - size/1.2)
                b.Visible = true
            else
                if Boxes[plr] then Boxes[plr].Visible = false end
            end

            if Tracers and vis then
                if not Lines[plr] then
                    local l = Drawing.new("Line")
                    l.Color = Color3.fromRGB(170,0,255)
                    l.Thickness = 1
                    Lines[plr] = l
                end

                local l = Lines[plr]
                l.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                l.To = Vector2.new(pos.X, pos.Y)
                l.Visible = true
            else
                if Lines[plr] then Lines[plr].Visible = false end
            end
        else
            if Boxes[plr] then Boxes[plr].Visible = false end
            if Lines[plr] then Lines[plr].Visible = false end
        end

        if PlayerKillAura and hitbox and (hitbox.Position - myRoot.Position).Magnitude <= 140 then
            ReplicatedStorage.Remotes.Blades.Hit:FireServer(hitbox, 999)
        end

        if AutoFarmPlayers and char and hitbox and HasTool(plr) then
            if FarmMode == "Players" or FarmMode == "Both" then
                local tween = TweenService:Create(
                    myRoot,
                    TweenInfo.new(TweenSpeed, Enum.EasingStyle.Linear),
                    {CFrame = hitbox.CFrame * CFrame.new(0,0,3)}
                )
                tween:Play()
                ReplicatedStorage.Remotes.Blades.Hit:FireServer(hitbox, 999)
            end
        end

        if AutoFarmPlayers and nape then
            if FarmMode == "Titans" or FarmMode == "Both" then
                local tween = TweenService:Create(
                    myRoot,
                    TweenInfo.new(TweenSpeed, Enum.EasingStyle.Linear),
                    {CFrame = nape.CFrame * CFrame.new(0,0,3)}
                )
                tween:Play()
                ReplicatedStorage.Remotes.Blades.Hit:FireServer(nape, 999)
            end
        end
    end
end)

