local function loadImage(name, url)  
    local asset = "rbxthumb://type=Asset&id=0&w=420&h=420"  
    pcall(function()  
        local getasset = getsynasset or getcustomasset  
        if getasset and writefile then  
            if not isfile(name) then  
                writefile(name, game:HttpGet(url))  
            end  
            asset = getasset(name)  
        end  
    end)  
    return asset  
end  

